# ──────────────────────────────────────────────
# Base de dados PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://horas:horas_secret@localhost:5432/horas_voo"

# ──────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────

# URL pública da aplicação (sem barra no final)
NEXTAUTH_URL="https://seu-app.railway.app"

# Segredo para assinar os tokens JWT.
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="substitua-por-um-segredo-longo-e-aleatorio"

# ──────────────────────────────────────────────
# Server Actions encryption (opcional, mas recomendado
# quando se usa múltiplas instâncias / rolling deploy)
# Gerar com: openssl rand -base64 32
# ──────────────────────────────────────────────
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="chave-base64-de-32-bytes"

# ──────────────────────────────────────────────
# Docker Compose (apenas para deploy local)
# ──────────────────────────────────────────────
POSTGRES_USER=horas
POSTGRES_PASSWORD=horas_secret
POSTGRES_DB=horas_voo
